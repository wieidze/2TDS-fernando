#include <stdio.h>

void soma(int a, int b) {
    printf("Total: %d\n", a + b);
}

void subtracao(int a, int b) {
    printf("Total: %d\n", a - b);
}

void multiplicao(int a, int b) {
    printf("Total: %d\n", a * b);
}

void divicao(int a, int b) {
    if (b == 0) {
        printf("Erro: Divisão por zero!\n");
    } else {
        printf("Total: %.2f\n", (float)a / b);
    }
}

int main() {
    int opcao, v1, v2;

    printf("Escolha uma opção:\n");
    printf("1 - Soma\n2 - Subtração\n3 - Multiplicacao\n4 - Divisão\n");
    scanf("%d", &opcao);

    if (opcao >= 1 && opcao <= 4) {
        printf("Digite dois números: ");
        scanf("%d %d", &v1, &v2);
    }

    switch(opcao) {
        case 1:
            soma(v1, v2);
            break;
        case 2:
            subtracao(v1, v2);
            break;
        case 3:
            multiplicao(v1, v2);
            break;
        case 4:
            divicao(v1, v2);
            break;
        default:
            printf("Opção inválida!\n");
    }

    return 0;
}
