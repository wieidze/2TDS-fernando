#include <stdio.h>

int main() {
    int opcao;
    int saldo = 1000; 
    int valor;

    do {
        printf("\n===== BANCO =====\n");
        printf("1 - Ver saldo\n");
        printf("2 - Depositar\n");
        printf("3 - Sacar\n");
        printf("4 - Sair\n");
        printf("Escolha: ");
        scanf("%d", &opcao);

        switch(opcao) {
            case 1:
                printf("Seu saldo é: R$ %d\n", saldo);
                break;

            case 2:
                printf("Digite o valor para depositar: ");
                scanf("%d", &valor);

                if (valor > 0) {
                    saldo += valor;
                    printf("Depósito realizado!\n");
                } else {
                    printf("Valor inválido!\n");
                }
                break;

            case 3:
                printf("Digite o valor para sacar: ");
                scanf("%d", &valor);

                if (valor > saldo) {
                    printf("Saldo insuficiente!\n");
                } else if (valor <= 0) {
                    printf("Valor inválido!\n");
                } else {
                    saldo -= valor;
                    printf("Saque realizado!\n");
                }
                break;

            case 4:
                printf("Saindo...\n");
                break;

            default:
                printf("Opção inválida!\n");
        }

    } while(opcao != 4);

    return 0;
}
